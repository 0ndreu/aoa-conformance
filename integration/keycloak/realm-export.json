{
  "realm": "mcp",
  "enabled": true,
  "components": {
    "org.keycloak.services.clientregistration.policy.ClientRegistrationPolicy": [
      {
        "name": "Allowed Client Scopes",
        "providerId": "allowed-client-templates",
        "subType": "anonymous",
        "config": { "allow-default-scopes": ["true"] }
      },
      {
        "name": "Max Clients Limit",
        "providerId": "max-clients",
        "subType": "anonymous",
        "config": { "max-clients": ["200"] }
      },
      {
        "name": "Allowed Protocol Mapper Types",
        "providerId": "allowed-protocol-mappers",
        "subType": "anonymous",
        "config": {
          "allowed-protocol-mapper-types": [
            "oidc-usermodel-property-mapper",
            "oidc-usermodel-attribute-mapper",
            "oidc-address-mapper",
            "oidc-full-name-mapper",
            "oidc-sha256-pairwise-sub-mapper",
            "oidc-audience-mapper"
          ]
        }
      }
    ]
  },
  "clientScopes": [
    {
      "name": "mcp:read",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    }
  ],
  "clients": [
    {
      "clientId": "mcp-conform",
      "enabled": true,
      "publicClient": false,
      "secret": "conform-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:*", "https://localhost:*", "http://127.0.0.1:*"],
      "optionalClientScopes": ["mcp:read"],
      "attributes": { "dpop.bound.access.tokens": "false" },
      "protocolMappers": [
        {
          "name": "mcp-aud",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "mcp-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "gateway-exchange-aud",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "mcp-gateway",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "mcp-par",
      "enabled": true,
      "publicClient": false,
      "secret": "par-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:*", "https://localhost:*", "http://127.0.0.1:*"],
      "optionalClientScopes": ["mcp:read"],
      "attributes": {
        "require.pushed.authorization.requests": "true"
      }
    },
    {
      "clientId": "mcp-gateway",
      "enabled": true,
      "publicClient": false,
      "secret": "gateway-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "optionalClientScopes": ["mcp:read"],
      "attributes": { "standard.token.exchange.enabled": "true" },
      "protocolMappers": [
        {
          "name": "downstream-aud",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "downstream-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "downstream-api",
      "enabled": true,
      "publicClient": false,
      "secret": "downstream-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "attributes": { "standard.token.exchange.enabled": "true" },
      "protocolMappers": [
        {
          "name": "downstream-self-aud",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "downstream-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Example",
      "credentials": [{ "type": "password", "value": "alice", "temporary": false }]
    }
  ]
}
